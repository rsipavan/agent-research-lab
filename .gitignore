# env / secrets
.env
*.env
!.env.example

# python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/

# runtime traces (the committed example traces under examples/ are kept;
# ad-hoc runs land in traces/ and are ignored)
traces/*.jsonl
!traces/.gitkeep

# per-run output bundles (committed polished examples live in examples/;
# ad-hoc runs land in runs/<run_id>/ and are ignored)
runs/*
!runs/.gitkeep

# editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
