# Copy to .env and fill in. .env is gitignored.

# --- LLM backend ---
# The pipeline needs an LLM for thesis extraction (and an optional report-narration
# step). It auto-detects, in this order:
#   1. the `claude` CLI on your PATH (Claude Code)  -> no key needed, uses your subscription. DEFAULT.
#   2. ANTHROPIC_API_KEY set                        -> Anthropic API (pip install 'agent-research-lab[anthropic]')
#   3. GEMINI_API_KEY set                           -> Gemini API, free tier covers it (pip install 'agent-research-lab[gemini]')
# If you have the `claude` CLI, you can leave everything in this section blank.
#
# Force a specific backend (otherwise auto-detected): claude_cli | anthropic | gemini
AGENT_RESEARCH_LAB_LLM=

# Only needed for the Anthropic API backend (get one at console.anthropic.com — pay-as-you-go).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Only needed for the Gemini API backend (get one free at aistudio.google.com/apikey).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Telegram ---
# Bot token from @BotFather. Required for the telegram_bot listener; not needed for
# the one-shot orchestrate CLI.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot. Empty = anyone (not
# recommended for a public deployment).
TELEGRAM_ALLOWLIST=

# --- TradingView MCP ---
# Validation runs go through the TradingView MCP. Set ONE of these:
#   TRADINGVIEW_MCP_CMD — the command that launches the MCP server (stdio transport).
#                         e.g. node C:/Users/you/tradingview-mcp/src/server.js
#                         The MCP drives the TradingView Desktop app, so that app must be
#                         running (with CDP enabled) for data calls to succeed — if it
#                         isn't, the MCP returns an error and the report says
#                         "untestable — validation failed: ..." (handled, not crashed).
#   TRADINGVIEW_MCP_URL — an HTTP/SSE endpoint, if you run the MCP server that way instead.
# If neither is set, validation steps report "untestable — MCP not configured".
# See docs/validation_logic.md.
TRADINGVIEW_MCP_CMD=
TRADINGVIEW_MCP_URL=
