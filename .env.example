# Copy to .env and fill in. .env is gitignored.

# Telegram bot token (from @BotFather). Required for the telegram_bot listener.
# Not needed for the one-shot orchestrate CLI.
TELEGRAM_BOT_TOKEN=

# Anthropic API key — used for thesis extraction (transcript -> testable claims)
# and report synthesis.
ANTHROPIC_API_KEY=

# Model to use. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Allowlist: comma-separated Telegram user IDs permitted to use the bot.
# Leave empty to allow anyone (not recommended for a public deployment).
TELEGRAM_ALLOWLIST=

# TradingView MCP endpoint. The MCP server must be running and reachable.
# See docs/validation_logic.md for setup. Defaults to the local stdio transport
# if unset; set this only if you run the MCP over HTTP/SSE.
TRADINGVIEW_MCP_URL=
